{
  "name": "@njstore/ui",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --environment jsdom --passWithNoTests",
    "test:coverage": "vitest run --environment jsdom --coverage --coverage.provider=v8 --coverage.reporter=text-summary --coverage.reporter=lcov --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "dependencies": {
    "@njstore/utils": "*",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.483.0",
    "tailwind-merge": "^3.3.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.2.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
