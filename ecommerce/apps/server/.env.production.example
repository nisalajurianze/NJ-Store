NODE_ENV=production
LOG_LEVEL=info
LOG_FILE_ENABLED=true
LOG_FILE_DIR=.logs
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=5
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority&appName=<app>
REDIS_URL=rediss://:<password>@<render-keyvalue-host>:<port>
JWT_ACCESS_SECRET=replace-with-64-char-random-string
JWT_REFRESH_SECRET=replace-with-64-char-random-string
JWT_EMAIL_SECRET=replace-with-64-char-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=NJ Store
CLIENT_URL=https://www.example.com
ADMIN_URL=https://admin.example.com
FREE_SHIPPING_THRESHOLD=15000
LOW_STOCK_THRESHOLD=5
APP_NAME=NJ Store
COOKIE_DOMAIN=.example.com
