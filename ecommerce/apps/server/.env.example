NODE_ENV=development
LOG_LEVEL=info
LOG_FILE_ENABLED=false
LOG_FILE_DIR=.logs
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=5
PORT=5000
MONGO_ROOT_USERNAME=njstore
MONGO_ROOT_PASSWORD=njstore-dev-mongo-password
MONGO_URI=mongodb://njstore:njstore-dev-mongo-password@127.0.0.1:27017/njstore?authSource=admin&replicaSet=rs0
REDIS_URL=redis://:njstore-dev-redis-password@127.0.0.1:6379
JWT_ACCESS_SECRET=replace-with-64-char-random-string
JWT_REFRESH_SECRET=replace-with-64-char-random-string
JWT_EMAIL_SECRET=replace-with-64-char-random-string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASS=
RESEND_API_KEY=
EMAIL_FROM=no-reply@yourdomain.com
EMAIL_FROM_NAME=NJ Store
CLIENT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174
FREE_SHIPPING_THRESHOLD=15000
LOW_STOCK_THRESHOLD=5
APP_NAME=NJ Store
COOKIE_DOMAIN=localhost
DEV_MEMORY_MONGO_FALLBACK=true
DEV_SEED_MEMORY_MONGO=true
SEED_ADMIN_PASSWORD=
SEED_CUSTOMER_PASSWORD=
