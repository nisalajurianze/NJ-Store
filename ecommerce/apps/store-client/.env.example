# Leave this as a relative path for local development so Vite can proxy API requests.
# For Vercel production deployments, use an absolute URL like https://api.example.com/api/v1.
VITE_API_URL=/api/v1
VITE_API_TIMEOUT_MS=30000
VITE_GOOGLE_CLIENT_ID=
VITE_SITE_URL=https://www.example.com
VITE_ANALYTICS_ENDPOINT=

# Optional build-time endpoint for enriching sitemap.xml with live catalog URLs.
SITEMAP_API_URL=
